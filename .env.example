# Output folders
SCRAPPED_FILES_DIR=scrapped files
HTML_DUMPS_DIR=html dumps
OBSIDIAN_VAULT_DIR=C:\PROJECTS-CODE\Vaults\Ideaverse\Atlas\Sources\Facebook Reels

# Optional: force a specific HTML dump instead of the newest file in HTML_DUMPS_DIR
# FB_REELS_HTML=html dumps/20260621 - Facebook Reels.html

# Metadata defaults written to CSV and Obsidian
EXTRACTION_TYPE=Facebook Shorts Scraper
SOURCE_LABEL=Facebook Reel
VIDEO_TYPE=Short Video

# Publish date lookup for new videos (uses Chrome in background)
FETCH_PUBLISH_DATES=true
HEADLESS=true

# Chrome profile used for publish-date lookup
# CHROME_USER_DATA_DIR=C:\Users\Frank\AppData\Local\Google\Chrome\User Data
# CHROME_PROFILE_DIRECTORY=Default
# CHROME_AUTOMATION_DIR=chrome_automation
# CHROME_DEBUG_PORT=9222
